# GitHub Self-Hosted Runner Configuration
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (required)
# For organization runners: needs 'admin:org' scope
# For repository runners: needs 'repo' scope and admin access to the repository
COMPANY_TOKEN=your_company_token_here

# GitHub organization name (required)
GITHUB_OWNER=Bridge-Placement

# GitHub repository name (required only for repo mode)
# Leave empty when using organization mode
GITHUB_REPO=your-repo-name

# Registration mode: 'org' for organization-level, 'repo' for repository-level
# Organization mode: Runner will be available to all repos in the organization
# Repository mode: Runner will be available only to the specific repository
REGISTRATION_MODE=org/repo

# Runner configuration (optional - defaults will be used if not specified)
RUNNER_NAME=docker-runner-$(hostname)
RUNNER_WORKDIR=/workspace
RUNNER_LABELS=self-hosted,docker,linux

# Example configurations:

# For organization-level runner (recommended for Bridge-Placement):
# COMPANY_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_OWNER=Bridge-Placement
# GITHUB_REPO=
# REGISTRATION_MODE=org

# For repository-specific runner:
# COMPANY_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_OWNER=Bridge-Placement
# GITHUB_REPO=specific-repo-name
# REGISTRATION_MODE=repo
